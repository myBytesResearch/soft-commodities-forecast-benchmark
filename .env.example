# =========================================================================
# soft-commodities-forecast-benchmark — environment variables
# =========================================================================
# Copy this file to .env and fill in the values that apply to your setup.
# The .env file is gitignored and never committed.

# -------------------------------------------------------------------------
# MLflow tracking
# -------------------------------------------------------------------------
# Local SQLite store (default; works out of the box):
MLFLOW_TRACKING_URI=sqlite:///./mlflow.db

# Or point to a remote tracking server:
# MLFLOW_TRACKING_URI=http://localhost:5000

# -------------------------------------------------------------------------
# Data cache
# -------------------------------------------------------------------------
# Where to cache yfinance snapshots after fetch.
# Directory must be writable and is gitignored.
DATA_CACHE_DIR=./data/cache

# -------------------------------------------------------------------------
# yfinance snapshot date pinning
# -------------------------------------------------------------------------
# Pin the fetch end-date so reproductions are deterministic across days.
# Source: Yahoo Finance / ICE Continuous Futures (CC=F, KC=F, SB=F, CT=F).
# Note: Yahoo Finance Terms of Service forbid data redistribution.
#       This repo ships code, not data.
SNAPSHOT_END_DATE=2024-12-31

# -------------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------------
# loguru level: TRACE / DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# Random seed
# -------------------------------------------------------------------------
# Used everywhere a stochastic component appears (default 42).
RANDOM_SEED=42
